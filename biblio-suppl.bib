@article{Nespoulet2011,
	title = {L'occupation humaine de l'abri {Pataud} ({Les} {Eyzies}-de-{Tayac}, {Dordogne}) il y a 22 000 ans: problématique et résultats préliminaires des fouilles du niveau 2},
	abstract = {In this paper, we present the irst elements of response to the question: “What is the status of the human remains in the Final Gravettian Level (Level 2) at Abri Pataud?” In 2005, more than forty years after the exca­ vations of H. L. Movius, a new project concerning level 2 was initiated at Abri Pataud. This project was conceived according to three simultaneous and complementary approaches: 1) a detailed analysis of archives; 2) a study of the Movius collections; 3) a new excavation with both archaeolo­ gical and geoarchaeological objectives. The initial results of the 2005 and 2006 excavations have conirmed that we can indeed appreciably improve our understanding of this archaeological level. Certain elements, such as the presence of very small backed bladelets, already permit us to more precisely deine the originality of this culture. A irst approach to the human remains (more than 250, MNI=6) led us to consider the hypothesis of a “disturbed primary burial”. This hypothesis is conirmed by preliminary results concerning the signiicant assemblage of “particular artefacts” associated with the human remains, most notably mammoth ivory beads.},
	language = {fr},
	author = {Nespoulet, R and Chiotti, Laurent and Gambier, Dominique and Agsous, Safia and Lenoble, Arnaud and Morala, André and Guillermin, Patricia and Vercoutère, Carole},
	year = {2011},
	keywords = {à lire, archéozoologie, géoarchéologie, industries lithiques, niveau 2, Pataud, Solutréen},
	pages = {11},
	file = {Nespoulet et al. - L'occupation humaine de l'abri Pataud (Les Eyzies-.pdf:/home/anais-luiza-vignoles/snap/zotero-snap/common/Zotero/storage/4W4PLDKH/Nespoulet et al. - L'occupation humaine de l'abri Pataud (Les Eyzies-.pdf:application/pdf},
}

