	pages = {367--378},
	file = {HAL Snapshot:/home/anais-luiza-vignoles/snap/zotero-snap/common/Zotero/storage/6D5TH3B7/halshs-00439398.html:text/html},
}

@phdthesis{Faivre2024,
	type = {Accreditation to supervise research},
	title = {Les technocomplexes lithiques du {Paléolithique} moyen récent dans le sud-ouest de la {France} : historique, recherches, enjeux.},
	shorttitle = {Les technocomplexes lithiques du {Paléolithique} moyen récent dans le sud-ouest de la {France}},
	url = {https://hal.science/tel-05004109},
	abstract = {Fondé sur une synthèse de mes travaux sur le Paléolithique moyen récent dans le sudouest de la France, et enrichi des apports fondamentaux de la recherche menée au sein de cette géographie depuis plusieurs décennies, ce travail s’inscrit dans un cadre réflexif sur les approches en technologie lithique et, plus spécifiquement, la notion de
« technocomplexe lithique » (TCL) communément utilisée dans les recherches sur le Paléolithique moyen. À partir de ce substrat à la fois théorique et méthodologique, donnant lieu à un long développement introductif, ce mémoire d’Habilitation à Diriger des Recherches s’organise en plusieurs parties (basées sur des contributions originales et/ou sur des travaux publiés) s’articulant autour des trois principaux axes structurants de ma recherche : 1) l’acquisition de données primaires à travers la fouille et l’étude du site de Combe-Grenal, contexte exceptionnel pour aborder la question de l’organisation chronologique des TCL du Paléolithique moyen récent à l’échelle régionale ; 2) les recherches portant sur l’identité technologique et techno-économique des différents TCL caractérisant le Moustérien dans le sud-ouest de la France ; 3) les réflexions sur les modes d’organisation socio-économique associés aux différents TCL et développés par les populations néandertaliennes dans le cadre de leurs stratégies de fréquentation et d’occupation des territoires aquitains. À la suite de ces développements, mettant en lumière à la fois la richesse et la diversité documentaire caractérisant la phase récente du Paléolithique moyen dans le Bassin aquitain, la dernière partie de ce travail, faisant office de synthèse, propose de dépasser ce cadre géographique pour s’ouvrir à une perception plus large mettant en perspective les TCL moustériens du Sud-Ouest avec les grands ensembles techno-culturels sub-contemporains (du SIM 5 au SIM 3) présents aux sein des espaces géographiques « voisins » constituant la partie médiane de la façade océanique de l’Europe.},
	urldate = {2026-06-25},
	school = {Université de Bordeaux},
	author = {Faivre, Jean-Philippe},
	month = oct,
	year = {2024},
	keywords = {chaîne opératoire, Europe de l'Ouest, human mobility, Late Middle Palaeolithic, lithic technology, mobilité humaine, Paléolithique moyen récent, southwestern France, sud-ouest de la France, techno-economic approach, techno-économie, technologie lithique, Western Europe},
	file = {HAL Snapshot:/home/anais-luiza-vignoles/snap/zotero-snap/common/Zotero/storage/RELRAE7W/tel-05004109.html:text/html},
}

@phdthesis{Cretin2000,
	type = {These de doctorat},
	title = {Tradition et variabilité dans le comportement technique : le cas du badegoulien et du magdalénien en {Périgord}},
	copyright = {Licence Etalab},
	shorttitle = {Tradition et variabilité dans le comportement technique},
	url = {https://theses.fr/2000PA010597},
	abstract = {L'identification et la caractérisation des industries lithiques du badegoulien (ou magdalenien ancien) se sont toujours heurtées à leur apparence polymorphe, voire archaïsante, ainsi qu'à la rareté du materiel osseux. Ce travail propose de rechercher, dans le comportement technique, des points communs susceptibles d'être attribués à une "tradition" badegoulienne et d'en suivre une postérité éventuelle. Le matériel lithique étudié provient de quatre gisements (les Jamblancs, Fouille Cleyet-Merle ; Laugerie-Haute est fouillés bordés ; Badégoule et Lachaud, fouilles Cheynier) qui présentent plusieurs niveaux archéologiques, allant du badegoulien ancien (ou magdalenien 0) au début du magdalenien moyen. Les éléments variants sont, eux aussi, examinés en détail, afin de mettre en lumière ceux qui peuvent être attribués aux sites eux-mêmes, et qui pourraient, dans ce cas, être imputés à des activités différentes, de ceux qui paraissent pouvoir être considérés comme chrono-culturellement significatifs parce qu'ils se retrouvent simultanément dans les gisements étudiés. Par la suite, une comparaison avec les principaux traits technologiques du magdalenien supérieur permet de mettre en exergue la specificiée technique de la période considérée et d'examiner la question de leur parenté. Enfin, les différents éléments de l'analyse que nous avons choisis, qu'il s'agisse de l'utilisation des matières premières, des modes de production des supports, de l'étude des outils ou bien des comparaisons avec le magdalénien supérieur, permettent de mettre en evidence une hierarchisation à l'interieur du système lithique. Celle-ci s'articule entre deux tendances : la souplesse d'un certain opportunisme et le poids de la norme. Cette structure technique constitue un important élément de compréhension du système lithique badégoulien et éclaire d'un jour nouveau sa variabilité.},
	urldate = {2026-06-25},
	school = {Paris 1},
	author = {Cretin, Catherine},
	collaborator = {Taborin, Yvette},
	month = jan,
	year = {2000},
	keywords = {Badegoulien -- France -- Périgord (France), Industrie lithique -- France -- Périgord (France), Magdalénien -- France -- Périgord (France)},
}

